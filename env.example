# Honcho Environment Variables
# Copy to .env and fill in your values

# =============================================================================
# Database (REQUIRED)
# =============================================================================
DB_CONNECTION_URI=postgresql+psycopg://用户名:密码@主机.fra.db.koyeb.com:5432/数据库名

# =============================================================================
# LLM Provider (REQUIRED)
# =============================================================================
LLM_OPENAI_API_KEY=你的LongCat_API_Key

# =============================================================================
# LLM Models - LongCat (5000万 tokens/天免费)
# =============================================================================

# Deriver (记忆提取 - 高频调用)
DERIVER_MODEL_CONFIG__MODEL=LongCat-Flash-Lite
DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.longcat.chat/openai/v1

# Summary (会话摘要)
SUMMARY_MODEL_CONFIG__MODEL=LongCat-Flash-Lite
SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.longcat.chat/openai/v1

# Dialectic (对话推理 - 5个级别)
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__MODEL=LongCat-Flash-Lite
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.longcat.chat/openai/v1

DIALECTIC_LEVELS__low__MODEL_CONFIG__MODEL=LongCat-Flash-Lite
DIALECTIC_LEVELS__low__MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.longcat.chat/openai/v1

DIALECTIC_LEVELS__medium__MODEL_CONFIG__MODEL=LongCat-Flash-Chat
DIALECTIC_LEVELS__medium__MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.longcat.chat/openai/v1

DIALECTIC_LEVELS__high__MODEL_CONFIG__MODEL=LongCat-Flash-Chat
DIALECTIC_LEVELS__high__MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.longcat.chat/openai/v1

DIALECTIC_LEVELS__max__MODEL_CONFIG__MODEL=LongCat-Flash-Thinking
DIALECTIC_LEVELS__max__MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.longcat.chat/openai/v1

# Dream (记忆整合)
DREAM_DEDUCTION_MODEL_CONFIG__MODEL=LongCat-Flash-Thinking
DREAM_DEDUCTION_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.longcat.chat/openai/v1

DREAM_INDUCTION_MODEL_CONFIG__MODEL=LongCat-Flash-Thinking
DREAM_INDUCTION_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.longcat.chat/openai/v1

# =============================================================================
# Embedding (NVIDIA)
# =============================================================================
EMBEDDING_MODEL_CONFIG__TRANSPORT=openai
EMBEDDING_MODEL_CONFIG__MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_MODEL_CONFIG__OVERRIDES__BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL_CONFIG__OVERRIDES__API_KEY_ENV=LLM_EMBEDDING_API_KEY
LLM_EMBEDDING_API_KEY=你的NVIDIA_API_Key

# =============================================================================
# Cache (可选)
# =============================================================================
CACHE_ENABLED=false
# CACHE_URL=redis://default:密码@主机.upstash.io:6379/0

# =============================================================================
# Vector Store
# =============================================================================
VECTOR_STORE_TYPE=pgvector
VECTOR_STORE_MIGRATED=false

# =============================================================================
# 降低内存占用 (512MB 免费层)
# =============================================================================
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DERIVER_WORKERS=1
